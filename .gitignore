# ─────────────────────────────────────────
#  Build output
# ─────────────────────────────────────────
build/
out/
bin/
lib/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# Compiled binaries
OpenGLRenderer
*.o
*.a
*.so
*.dylib
*.dSYM/

# ─────────────────────────────────────────
#  Assets (large files — track with Git LFS
#  or keep out of repo entirely)
# ─────────────────────────────────────────
assets/models/
assets/textures/
*.obj
*.fbx
*.blend
*.dae
*.png
*.jpg
*.jpeg
*.hdr
*.exr
*.tga
*.mtl
models

# Exception: keep small test assets if needed
# !assets/test/**

# ─────────────────────────────────────────
#  Web viewer (Node/Vite project)
# ─────────────────────────────────────────
web/node_modules/
web/dist/

# The asset ignores above (*.obj, *.fbx, *.dae, *.mtl, *.hdr, etc.) target
# the native renderer's large/vendored assets. The web viewer bundles its
# own small static assets (showcase model, HDRI lighting presets) and test
# fixtures in these formats — both must ship in the repo.
!web/public/**
!web/src/test/fixtures/**

# ─────────────────────────────────────────
#  VS Code
# ─────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# ─────────────────────────────────────────
#  macOS
# ─────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─────────────────────────────────────────
#  Logs and temp files
# ─────────────────────────────────────────
*.log
*.tmp
*.swp
*.swo
*~

# ─────────────────────────────────────────
#  Dependencies (vendored via package manager)
#  GLAD is an exception — it's generated source
#  that belongs in the repo
# ─────────────────────────────────────────
# external/         ← do NOT ignore, GLAD lives here
