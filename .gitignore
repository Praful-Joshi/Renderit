# ─────────────────────────────────────────
#  Build output
# ─────────────────────────────────────────
build/
out/
bin/
lib/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# Compiled binaries
OpenGLRenderer
*.o
*.a
*.so
*.dylib
*.dSYM/

# ─────────────────────────────────────────
#  Assets (large files — track with Git LFS
#  or keep out of repo entirely)
# ─────────────────────────────────────────
educational/assets/models/
educational/assets/textures/
*.obj
*.fbx
*.blend
*.dae
*.png
*.jpg
*.jpeg
*.hdr
*.exr
*.tga
*.mtl
models

# Exceptions: the extension's own icon and README screenshots aren't the
# native renderer's vendored assets the ignores above target — they're small,
# deliberately-committed docs/marketplace assets.
!vscode-extension/icon.png
!docs/images/**

# ─────────────────────────────────────────
#  Web viewer (Node/Vite project)
# ─────────────────────────────────────────
web/node_modules/
web/dist/

# The asset ignores above (*.obj, *.fbx, *.dae, *.mtl, *.hdr, etc.) target
# the native renderer's large/vendored assets. The web viewer bundles its
# own small static assets (showcase model, HDRI lighting presets) and test
# fixtures in these formats — both must ship in the repo.
!web/public/**
!web/src/test/fixtures/**

# ─────────────────────────────────────────
#  VS Code extension (Node/Vite project)
# ─────────────────────────────────────────
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/dist/
vscode-extension/.vscode-test/
vscode-extension/*.vsix

# Test fixtures, same exception as the web viewer above.
!vscode-extension/test/fixtures/**

# ...but not personal/scratch test assets someone drops in that same folder —
# re-ignored explicitly so a broad `git add` can't sweep up a large local
# test file (e.g. a real-world model zip used for manual testing).
vscode-extension/test/fixtures/bedroom.zip

# ─────────────────────────────────────────
#  VS Code
# ─────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# ─────────────────────────────────────────
#  macOS
# ─────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─────────────────────────────────────────
#  Logs and temp files
# ─────────────────────────────────────────
*.log
*.tmp
*.swp
*.swo
*~

# ─────────────────────────────────────────
#  Dependencies (vendored via package manager)
#  GLAD is an exception — it's generated source
#  that belongs in the repo
# ─────────────────────────────────────────
# educational/external/  ← do NOT ignore, GLAD lives here

/project_secrets